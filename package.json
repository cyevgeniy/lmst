{
  "name": "lmst",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "size-limit": [
    {
      "limit": "10 kB",
      "path": "dist/assets/*.js"
    }
  ],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.js && tsc && vite build && cp _redirects dist/_redirects",
    "preview": "vite preview",
    "test": "vitest run",
    "size": "npm run build && size-limit"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts}": "prettier --write"
  },
  "devDependencies": {
    "@size-limit/file": "^11.2.0",
    "@types/jsdom": "^21.1.5",
    "browserslist": "^4.23.2",
    "dotenv": "^16.6.1",
    "jsdom": "^22.1.0",
    "lightningcss": "^1.32.0",
    "nano-staged": "^0.8.0",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.13.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  }
}
